{
  "name": "fitfeky",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "cd frontend && vite --config vite.config.ts --port=3000 --host=0.0.0.0",
    "sitemap": "npx tsx scripts/generate-sitemap.ts",
    "build": "npm run sitemap && cd frontend && vite build --config vite.config.ts",
    "preview": "cd frontend && vite preview --config vite.config.ts",
    "clean": "rm -rf dist frontend/dist",
    "lint": "tsc --noEmit -p frontend/tsconfig.json",
    "fix-products": "tsx scripts/fix-products.ts"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.106.2",
    "@tailwindcss/vite": "^4.1.14",
    "@vercel/analytics": "^2.0.1",
    "@vercel/speed-insights": "^2.0.0",
    "@vitejs/plugin-react": "^5.0.4",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "react": "^19.0.1",
    "react-dom": "^19.0.1",
    "react-helmet-async": "^3.0.0",
    "react-router-dom": "^7.14.2",
    "vite": "^6.2.3"
  },
  "devDependencies": {
    "@types/node": "^22.14.0",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "tailwindcss": "^4.1.14",
    "terser": "^5.48.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.3"
  }
}
